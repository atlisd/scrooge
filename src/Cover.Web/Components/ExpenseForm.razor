@inject IApiClient Api

@if (_users is null)
{
    <div class="text-center py-3">
        <div class="spinner-border spinner-border-sm"></div>
    </div>
}
else
{
    <EditForm FormName="expense" Model="Model" OnValidSubmit="OnSubmit">
        <div class="mb-3">
            <label class="form-label">Amount (ISK)</label>
            <InputNumber class="form-control" @bind-Value="Model.Amount" @ref="amountInput" />
        </div>

        <div class="mb-3 position-relative" @onfocusout="HideSuggestionsDelayed">
            <label class="form-label">Merchant <span class="text-danger">*</span></label>
            <input class="form-control" value="@Model.Merchant"
                   @oninput="OnMerchantInput" autocomplete="off" placeholder="" />
            @if (_showSuggestions && _suggestions.Count > 0)
            {
                <ul class="list-group position-absolute w-100 shadow-sm" style="z-index:1000;top:100%">
                    @foreach (var s in _suggestions)
                    {
                        <li class="list-group-item list-group-item-action py-2"
                            @onmousedown="() => SelectSuggestion(s)"
                            @ontouchstart="() => SelectSuggestion(s)">@s</li>
                    }
                </ul>
            }
        </div>

        <div class="mb-3">
            <label class="form-label">Description <span class="text-muted small">(optional)</span></label>
            <InputText class="form-control" @bind-Value="Model.Description" />
        </div>

        <div class="mb-3">
            <label class="form-label">Paid by</label>
            <InputSelect class="form-select" @bind-Value="Model.PaidById">
                @foreach (var user in _users)
                {
                    <option value="@user.Id">@user.Name</option>
                }
            </InputSelect>
        </div>

        <div class="mb-3">
            <label class="form-label">Split type</label>
            <InputRadioGroup @bind-Value="Model.SplitType">
                <div class="form-check">
                    <InputRadio class="form-check-input" Value="SplitType.Equal" id="splitEqual" />
                    <label class="form-check-label" for="splitEqual">Split equally (50/50)</label>
                </div>
                <div class="form-check">
                    <InputRadio class="form-check-input" Value="SplitType.FullOther" id="splitFull" />
                    <label class="form-check-label" for="splitFull">Owed by other (100%)</label>
                </div>
            </InputRadioGroup>
        </div>

        <div class="mb-3">
            <label class="form-label">Date</label>
            <InputDate class="form-control" @bind-Value="Model.Date" />
        </div>

        @if (Error is not null)
        {
            <div class="alert alert-danger">@Error</div>
        }

        <button type="submit" class="btn btn-primary w-100" disabled="@Submitting">
            @if (Submitting)
            {
                <span class="spinner-border spinner-border-sm me-1"></span>
            }
            @ButtonText
        </button>
    </EditForm>
}

@code {
    [Parameter, EditorRequired] public ExpenseFormModel Model { get; set; } = null!;
    [Parameter, EditorRequired] public EventCallback OnSubmit { get; set; }
    [Parameter] public string ButtonText { get; set; } = "Save";
    [Parameter] public bool Submitting { get; set; }
    [Parameter] public string? Error { get; set; }
    [Parameter, EditorRequired] public List<UserDto>? Users { get; set; }

    private List<UserDto>? _users;
    private InputNumber<long?>? amountInput;
    private bool _focused;
    private List<string> _suggestions = [];
    private bool _showSuggestions;

    protected override void OnParametersSet()
    {
        _users = Users;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_focused && amountInput?.Element is not null)
        {
            _focused = true;
            await amountInput.Element.Value.FocusAsync();
        }
    }

    private async Task OnMerchantInput(ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? "";
        Model.Merchant = value;
        if (value.Length >= 1)
        {
            _suggestions = await Api.GetMerchantsAsync(value);
            _showSuggestions = true;
        }
        else
        {
            _suggestions = [];
            _showSuggestions = false;
        }
    }

    private void SelectSuggestion(string s)
    {
        Model.Merchant = s;
        _suggestions = [];
        _showSuggestions = false;
    }

    private async Task HideSuggestionsDelayed()
    {
        await Task.Delay(150);
        _showSuggestions = false;
        StateHasChanged();
    }

    public class ExpenseFormModel
    {
        public string Merchant { get; set; } = "";
        public string? Description { get; set; }
        public long? Amount { get; set; }
        public int PaidById { get; set; }
        public SplitType SplitType { get; set; } = SplitType.Equal;
        public DateOnly Date { get; set; } = DateOnly.FromDateTime(DateTime.Today);
    }
}
