@inject NavigationManager Nav

<div class="card mb-2 expense-card" @onclick="GoToEdit">
    <div class="card-body py-2 px-3">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <strong>@(Expense.Merchant ?? Expense.Description ?? "—")</strong>
                @if (!string.IsNullOrEmpty(Expense.Description) && !string.IsNullOrEmpty(Expense.Merchant))
                {
                    <br /><small class="text-muted">@Expense.Description</small>
                }
                <br />
                <small class="text-muted">
                    @Expense.PaidByName paid &middot; @Expense.Date.ToString("d MMM yyyy")
                    @if (Expense.SplitType != SplitType.Equal)
                    {
                        <span class="badge @BadgeClass split-badge ms-1">@BadgeText</span>
                    }
                </small>
            </div>
            <div class="text-end">
                <strong>@FormatIsk(Expense.Amount)</strong>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public ExpenseDto Expense { get; set; } = null!;

    private string BadgeClass => Expense.SplitType switch
    {
        SplitType.FullOther => "bg-warning text-dark",
        _ => ""
    };

    private string BadgeText => Expense.SplitType switch
    {
        SplitType.FullOther => "100% other",
        _ => ""
    };

    private void GoToEdit() => Nav.NavigateTo($"/edit/{Expense.Id}");

    private static string FormatIsk(long amount)
    {
        return amount.ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("is-IS")) + " kr.";
    }
}
