@inject CurrencyState Currency

@if (Balance is not null)
{
    <div class="card mb-3 balance-card @(Balance.OwedAmount == 0 ? "settled" : "owes")">
        <div class="card-body">
            @if (Balance.OwedAmount == 0)
            {
                <h5 class="card-title mb-0 text-success">All settled!</h5>
            }
            else
            {
                var owerName = Balance.OwesUserId == Balance.User1.UserId ? Balance.User1.Name : Balance.User2.Name;
                var owedName = Balance.IsOwedUserId == Balance.User1.UserId ? Balance.User1.Name : Balance.User2.Name;
                <h5 class="card-title mb-0">
                    <span class="text-danger">@owerName</span> owes
                    <span class="text-success">@owedName</span>
                    <strong>@Currency.Format(Balance.OwedAmount)</strong>
                </h5>
            }
        </div>
    </div>
}

@code {
    [Parameter] public BalanceDto? Balance { get; set; }
}
