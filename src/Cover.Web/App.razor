@using System.Globalization
@inject IApiClient Api
@inject NavigationManager Nav
@inject CurrencyState Currency
@inject IJSRuntime JS

@if (!_loaded)
{
    <div class="d-flex justify-content-center align-items-center" style="height: 100vh;">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <Router AppAssembly="@typeof(App).Assembly" NotFoundPage="typeof(Pages.NotFound)">
        <Found Context="routeData">
            <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
    </Router>
}

@code {
    private bool _loaded;

    private bool _cultureSet;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_cultureSet)
        {
            _cultureSet = true;
            try
            {
                var browserLang = await JS.InvokeAsync<string>(
                    "eval", "window.browserLanguage || navigator.language || 'en'");
                var culture = new CultureInfo(browserLang);
                CultureInfo.DefaultThreadCurrentCulture = culture;
                CultureInfo.DefaultThreadCurrentUICulture = culture;
                StateHasChanged();
            }
            catch { }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var status = await Api.GetSetupStatusAsync();
            Currency.Code = status.CurrencyCode;
            Currency.Decimals = status.CurrencyDecimals;

            if (!status.IsComplete)
            {
                _loaded = true;
                Nav.NavigateTo("/setup");
                return;
            }

            var isAuth = await Api.GetAuthStatusAsync();
            _loaded = true;

            if (!isAuth)
            {
                Nav.NavigateTo("/login");
                return;
            }

            var uri = Nav.Uri;
            if (uri.Contains("/setup") || uri.Contains("/login"))
            {
                Nav.NavigateTo("/");
            }
        }
        catch
        {
            _loaded = true;
        }
    }
}
