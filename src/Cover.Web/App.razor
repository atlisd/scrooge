@using System.Globalization
@inject IApiClient Api
@inject NavigationManager Nav
@inject CurrencyState Currency

@if (!_loaded)
{
    <div class="d-flex justify-content-center align-items-center" style="height: 100vh;">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <Router AppAssembly="@typeof(App).Assembly" NotFoundPage="typeof(Pages.NotFound)">
        <Found Context="routeData">
            <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
    </Router>
}

@code {
    private bool _loaded;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var status = await Api.GetSetupStatusAsync();
            Currency.SetCurrency(status.CurrencyCode, status.CurrencyDecimals);

            if (Currency.Culture is not null)
            {
                CultureInfo.DefaultThreadCurrentCulture = Currency.Culture;
                CultureInfo.DefaultThreadCurrentUICulture = Currency.Culture;
            }

            if (!status.IsComplete)
            {
                _loaded = true;
                Nav.NavigateTo("/setup");
                return;
            }

            var isAuth = await Api.GetAuthStatusAsync();
            _loaded = true;

            if (!isAuth)
            {
                Nav.NavigateTo("/login");
                return;
            }

            var uri = Nav.Uri;
            if (uri.Contains("/setup") || uri.Contains("/login"))
            {
                Nav.NavigateTo("/");
            }
        }
        catch
        {
            _loaded = true;
        }
    }
}
