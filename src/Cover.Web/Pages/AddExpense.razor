@page "/add"
@inject IApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS

<h4 class="mb-3">Add Expense</h4>

<div class="row">
    <div class="col-md-6">
        <ExpenseForm Model="_model" OnSubmit="Submit" Users="_users"
                     ButtonText="Add Expense" Submitting="_submitting" Error="@_error" />
    </div>
</div>

@code {
    private ExpenseForm.ExpenseFormModel _model = new();
    private List<UserDto>? _users;
    private bool _submitting;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        _users = await Api.GetUsersAsync();
        if (_users.Count > 0)
        {
            var stored = await JS.InvokeAsync<string?>("localStorage.getItem", "lastPaidById");
            _model.PaidById = int.TryParse(stored, out var id) && _users.Any(u => u.Id == id)
                ? id
                : _users[0].Id;
        }
    }

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_model.Merchant))
        {
            _error = "Merchant is required.";
            return;
        }
        if (_model.Amount is null or <= 0)
        {
            _error = "Amount must be positive.";
            return;
        }

        _submitting = true;
        _error = null;
        try
        {
            await Api.CreateExpenseAsync(new CreateExpenseRequest(
                _model.Merchant.Trim(), _model.Description?.Trim(), _model.Amount.Value, _model.SplitType,
                _model.PaidById, _model.Date));
            await JS.InvokeVoidAsync("localStorage.setItem", "lastPaidById", _model.PaidById.ToString());
        }
        catch (Exception ex)
        {
            _error = $"Failed to add expense: {ex.Message}";
            _submitting = false;
            return;
        }

        _submitting = false;
        Nav.NavigateTo("/");
    }
}
