@page "/edit/{Id:int}"
@inject IApiClient Api
@inject NavigationManager Nav

<h4 class="mb-3">Edit Expense</h4>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border"></div>
    </div>
}
else if (_notFound)
{
    <div class="alert alert-warning">Expense not found.</div>
}
else
{
    <div class="row">
        <div class="col-md-6">
            <ExpenseForm Model="_model" OnSubmit="Submit" Users="_users"
                         ButtonText="Save Changes" Submitting="_submitting" Error="@_error" />

            <button class="btn btn-outline-danger w-100 mt-2" @onclick="ConfirmDelete" disabled="@_submitting">
                Delete Expense
            </button>

            @if (_showDeleteConfirm)
            {
                <div class="alert alert-danger mt-2">
                    <p class="mb-2">Are you sure you want to delete this expense?</p>
                    <button class="btn btn-danger btn-sm me-2" @onclick="Delete">Yes, delete</button>
                    <button class="btn btn-secondary btn-sm" @onclick="() => _showDeleteConfirm = false">Cancel</button>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private ExpenseForm.ExpenseFormModel _model = new();
    private List<UserDto>? _users;
    private bool _loading = true;
    private bool _notFound;
    private bool _submitting;
    private bool _showDeleteConfirm;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var usersTask = Api.GetUsersAsync();
        var expenseTask = Api.GetExpenseAsync(Id);

        _users = await usersTask;
        var expense = await expenseTask;

        if (expense is null)
        {
            _notFound = true;
        }
        else
        {
            _model.Merchant = expense.Merchant ?? "";
            _model.Description = expense.Description;
            _model.Amount = expense.Amount;
            _model.PaidById = expense.PaidById;
            _model.SplitType = expense.SplitType;
            _model.Date = expense.Date;
        }

        _loading = false;
    }

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_model.Merchant))
        {
            _error = "Merchant is required.";
            return;
        }
        if (_model.Amount is null or <= 0)
        {
            _error = "Amount must be positive.";
            return;
        }

        _submitting = true;
        _error = null;
        try
        {
            await Api.UpdateExpenseAsync(Id, new UpdateExpenseRequest(
                _model.Merchant.Trim(), _model.Description?.Trim(), _model.Amount.Value, _model.SplitType,
                _model.PaidById, _model.Date));
            Nav.NavigateTo("/");
        }
        catch (Exception ex)
        {
            _error = $"Failed to update: {ex.Message}";
        }
        finally
        {
            _submitting = false;
        }
    }

    private void ConfirmDelete() => _showDeleteConfirm = true;

    private async Task Delete()
    {
        _submitting = true;
        try
        {
            await Api.DeleteExpenseAsync(Id);
            Nav.NavigateTo("/");
        }
        catch (Exception ex)
        {
            _error = $"Failed to delete: {ex.Message}";
            _showDeleteConfirm = false;
        }
        finally
        {
            _submitting = false;
        }
    }
}
